# Investec Swag SSH — Environment Variables

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=file:./data/swag.db
# DATABASE_AUTH_TOKEN=             # For Turso (production)

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me-in-production
ADMIN_INITIAL_EMAIL=admin@investec.com
ADMIN_INITIAL_PASSWORD=changeme123

# ── SSH Server ──────────────────────────────────────────────────
SSH_HOST_KEY_PATH=./data/host_key
SSH_PORT=2222

# ── API ─────────────────────────────────────────────────────────
API_PORT=3000
API_URL=http://localhost:3000
POWER_AUTOMATE_FLOW_TOKEN=change-me
